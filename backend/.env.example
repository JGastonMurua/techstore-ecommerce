# Copiá este archivo como .env y completá con tus datos reales
# NUNCA subas el .env al repositorio

PORT=3001

# Resend — para emails de confirmacion de pedido
# Obtenerlo en: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Mercado Pago — Access Token (prueba o produccion)
# Obtenerlo en: mercadopago.com.ar/developers → Tu aplicacion → Credenciales
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
