# Copiá este archivo como .env y completá con tus datos reales
# NUNCA subas el .env al repositorio

PORT=3001

# Gmail del remitente
EMAIL_USER=tu-email@gmail.com

# App Password de Google (no la contraseña normal)
# Para generarla: myaccount.google.com > Seguridad > Verificacion en 2 pasos > Contrasenas de aplicaciones
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Nombre que aparece como remitente
EMAIL_FROM=TechStore <tu-email@gmail.com>
